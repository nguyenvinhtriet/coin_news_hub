# ==========================================
# CẤU HÌNH ENVIRONMENT VARIABLES CHO VERCEL
# ==========================================
# Hướng dẫn:
# 1. Copy file này thành `.env` để chạy ở Local.
# 2. Trên Vercel, vào mục Settings > Environment Variables và thêm các biến này.
# 3. Các biến bắt đầu bằng NEXT_PUBLIC_ sẽ được dùng trực tiếp trên trình duyệt (Client-side).
# 4. Các biến không có NEXT_PUBLIC_ chỉ chạy trên Server (API Routes) để bảo mật.

# 1. SUPABASE (Bắt buộc để lưu trữ tin tức và báo cáo)
# Lấy tại: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 2. GEMINI API (Bắt buộc để AI phân tích)
# Lấy tại: Google AI Studio > Get API Key
GEMINI_API_KEY=your-gemini-api-key

# 3. TELEGRAM BOT (Bắt buộc nếu muốn gửi báo cáo qua Telegram)
# Lấy tại: BotFather trên Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Lấy Chat ID bằng cách chat với bot @userinfobot hoặc thêm bot vào group
TELEGRAM_CHAT_ID=your-telegram-chat-id

# 4. BẢO MẬT ĐĂNG NHẬP (Tuỳ chọn, nếu không có sẽ dùng mật khẩu mặc định trong code)
# Tạo mã băm SHA-256 cho mật khẩu của bạn (Ví dụ: Admin@123q -> 51ca4d506b7c02bb4e779be45a4b4b85516b2294dfd11db96f15d9bd97287c2c)
NEXT_PUBLIC_ADMIN_PASSWORD_HASH=51ca4d506b7c02bb4e779be45a4b4b85516b2294dfd11db96f15d9bd97287c2c

# 5. CẤU HÌNH MẶC ĐỊNH (Tuỳ chọn)
# Danh sách các link RSS mặc định (cách nhau bằng dấu phẩy hoặc xuống dòng)
# NEXT_PUBLIC_RSS_URLS=https://cointelegraph.com/rss,https://www.coindesk.com/arc/outboundfeeds/rss/
# Tiêu chí đánh giá mặc định
# NEXT_PUBLIC_HOT_CRITERIA=Đánh giá xem tin tức này có mức độ Critical (nghiêm trọng) hoặc Hot (nóng) đối với thị trường tài chính, chứng khoán toàn cầu và Crypto hay không. Chấm điểm từ 1-10 và giải thích ngắn gọn.

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
